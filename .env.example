# Copy to .env and adjust. `make dev` will create .env from this file if missing.

# --- Required (Phases 1–6) ---
# yfinance is the primary data source and needs NO API key.
# Synchronous stack on the psycopg (psycopg3) driver — see ADR-009.
DATABASE_URL=postgresql+psycopg://quantforge:password@localhost:5432/quantforge
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
LOG_LEVEL=INFO
# `memory` (default; standalone `uvicorn` just works without Docker) or `timescale`
# (production / docker-compose). `make dev` overrides this to `timescale` via the
# compose service env. Required when DATABASE_URL points at a real Postgres.
STORAGE_BACKEND=memory

# --- Phase 3+ optional (second data vendor) ---
# POLYGON_API_KEY=your_key_here        # polygon.io — only needed when the Polygon adapter lands

# --- Phase 8 only (alternative data) ---
# REDDIT_CLIENT_ID=your_id_here
# REDDIT_CLIENT_SECRET=your_secret_here
# REDDIT_USER_AGENT=QuantForge/1.0
# NEWS_API_KEY=your_key_here
